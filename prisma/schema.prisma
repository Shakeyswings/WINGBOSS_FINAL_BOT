generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/*
Dormant models until:
  RUNTIME_MODE=server
  BACKEND_MODE=db
*/

model User {
  id        String @id
  createdAt DateTime @default(now())
}

model Order {
  id        String   @id
  createdAt DateTime @default(now())
}
